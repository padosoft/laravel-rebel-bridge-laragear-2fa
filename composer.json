{
    "name": "padosoft/laravel-rebel-bridge-laragear-2fa",
    "description": "Bridge between laragear/two-factor and Laravel Rebel: exposes TOTP as an AAL2 step-up driver, integrates recovery codes, and emits full audit telemetry into the Rebel audit trail. Part of padosoft/laravel-rebel-*.",
    "keywords": ["laravel", "authentication", "totp", "two-factor", "step-up", "laragear", "padosoft", "rebel"],
    "homepage": "https://github.com/padosoft/laravel-rebel-bridge-laragear-2fa",
    "license": "MIT",
    "authors": [
        {
            "name": "Padosoft",
            "email": "support@padosoft.com",
            "homepage": "https://www.padosoft.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/contracts": "^12.0|^13.0",
        "illuminate/support": "^12.0|^13.0",
        "padosoft/laravel-rebel-core": "^0.1",
        "padosoft/laravel-rebel-step-up": "^0.1",
        "spatie/laravel-package-tools": "^1.92"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laragear/two-factor": "^4.0",
        "padosoft/laravel-rebel-email-otp": "^0.1",
        "laravel/pint": "^1.18",
        "orchestra/testbench": "^10.0|^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0"
    },
    "suggest": {
        "laragear/two-factor": "Enables the laragear_totp step-up driver and TOTP/recovery-code verification. Install it and add the TwoFactorAuthentication trait to your User model."
    },
    "autoload": {
        "psr-4": {
            "Padosoft\\Rebel\\Bridge\\Laragear2fa\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Padosoft\\Rebel\\Bridge\\Laragear2fa\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Padosoft\\Rebel\\Bridge\\Laragear2fa\\RebelLaragear2faBridgeServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "pest",
        "phpstan": "phpstan analyse --memory-limit=512M",
        "pint": "pint",
        "check": [
            "@pint --test",
            "@phpstan",
            "@test"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
